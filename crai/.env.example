# .env.example — copie para .env e preencha
# cp .env.example .env

# ── Anthropic (obrigatório para dunning e mensagens de retenção) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (opcional — simulação local funciona sem) ───────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── HubSpot CRM (opcional — sem token roda em modo simulação) ──────
# 1. hubspot.com → Settings → Integrations → Private Apps → Create
# 2. Permissões: crm.objects.contacts.write + crm.objects.deals.write
# 3. No HubSpot, criar 2 pipelines:
#    - "crai_recovery"  (stages: diagnosing, retrying, dunning_sent, recovered, lost)
#    - "crai_retention" (stages: risk_detected, offer_sent, retained, churned)
HUBSPOT_TOKEN=pat-na1-...

# ── Segment (opcional — simulação via /simulate/churn-risk funciona sem) ──
SEGMENT_WRITE_KEY=...
